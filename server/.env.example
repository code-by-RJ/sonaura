# ────────────────────────────────────────────────────────────
# SONAURA — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.
# ────────────────────────────────────────────────────────────

# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/sonaura?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────
# Use strong random strings (min 32 chars) — openssl rand -base64 48
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_different_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────
# Dev: Vite default port | Prod: your Netlify domain
CLIENT_URL=http://localhost:5173

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Resend (Transactional Email) ────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=SONAURA <noreply@yourdomain.com>

# ─── Razorpay ────────────────────────────────────────────────
# Use test keys for dev, live keys for production only
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
